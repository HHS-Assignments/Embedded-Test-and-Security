{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc-13 build active file",
            "command": "/usr/bin/gcc-13",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wno-stringop-overflow",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "label": "Run OrderVerwerken (incasso)",
            "type": "shell",
            "command": "${workspaceFolder}/OrderVerwerken/main",
            "args": [
                "ordersv3_incasso.txt"
            ],
            "options": {
                "cwd": "${workspaceFolder}/OrderVerwerken"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false,
                "focus": true
            },
            "dependsOn": "C/C++: gcc-13 build active file"
        },
        {
            "label": "Run OrderVerwerken (exploit)",
            "type": "shell",
            "command": "${workspaceFolder}/OrderVerwerken/main",
            "args": [
                "exploit_artikelnr.txt"
            ],
            "options": {
                "cwd": "${workspaceFolder}/OrderVerwerken"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false,
                "focus": true
            },
            "dependsOn": "C/C++: gcc-13 build active file"
        }
    ],
    "version": "2.0.0"
}